        rpy="0 0 0" />
      <geometry>
        <box size="0.10 0.12 0.73" />
      </geometry>
    </collision>
  </link>
  <joint
    name="column_joint"
    type="prismatic">
    <origin
      xyz="0.2905 0 0"
      rpy="0 0 0" />
    <parent
      link="turret_link" />
    <child
      link="column_link" />
        <axis
    xyz="0 0 1" />
  <limit
    lower="0.0"
    upper="0.9"
    effort="1000.0"
    velocity="0.1" />
  </joint>
  <!-- Add Gazebo materials for the oliwall links -->
  <gazebo reference="base_link">
      <collide_bitmask>0</collide_bitmask>
  </gazebo>

  <gazebo reference="turret_link">
      <collide_bitmask>0</collide_bitmask>
      <gravity>false</gravity>
  </gazebo>

  <gazebo reference="column_link">
    <collide_bitmask>0</collide_bitmask>
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="drivewhl_l_joint_link">
      <mu1>2.0</mu1>
      <mu2>2.0</mu2>
      <kp>5000000.0</kp>
      <kd>10.0</kd>
      <minDepth>0.002</minDepth>
      <maxVel>50.0</maxVel>
      <!-- <fdir1>1 0 0</fdir1> -->
  </gazebo>

  <gazebo reference="drivewhl_r_joint_link">
