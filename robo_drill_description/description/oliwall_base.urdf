      <origin
        xyz="0.05 0 0.05"
        rpy="0 0 0" />
      <mass value="10.0"/>
      <inertia
        ixx="0.625"
        ixy="0.0"
        ixz="0.0"
        iyy="0.875"
        iyz="0.0"
