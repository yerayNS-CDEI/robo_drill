    </inertial>
    <visual>
      <origin
        xyz="0 0 0.009"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/turret_textured.dae" />
      </geometry>
    </visual>
    <!-- Fixed outer sleeve for the lifting column.
         The prismatic child link is the moving inner column; this sleeve keeps the
         structure visually connected when the column is extended. -->
    <visual>
      <origin
        xyz="0.2905 0 0.45"
        rpy="0 0 0" />
      <geometry>
        <box size="0.10 0.12 0.9" />
      </geometry>
      <material
