      </geometry>
    </collision>
  </link>
  <joint
    name="drivewhl_r_joint"
    type="continuous">
    <origin
      xyz="0 -0.18275 0"
      rpy="-1.5708 0 0" />
    <parent
      link="base_link" />
    <child
      link="drivewhl_r_joint_link" />
    <axis
      xyz="0 0 1" />
    <limit effort="500.0" velocity="50.0"/>
  </joint>
