    <parent link="turret_link"/>
    <child link="turret_caster_br"/>
  </joint>


  
  <link
    name="column_link">
    <inertial>
      <origin
        xyz="0 0 0.0"
        rpy="0 0 0" />
      <mass value="1.0"/>
      <inertia
        ixx="0.04494166666666667"
