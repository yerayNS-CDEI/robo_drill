    <child link="turret_caster_br"/>
  </joint>


  
  <link
    name="gantry_lift1_link">
    <inertial>
      <origin
        xyz="0 0 0.0"
        rpy="0 0 0" />
      <mass value="0.5"/>
      <inertia
        ixx="0.022470833333333335"
        ixy="0.0"
        ixz="0.0"
        iyy="0.022354166666666668"
        iyz="0.0"
        izz="0.0004166666666666667"/>
    </inertial>
    <visual>
      <origin
        xyz="0.12 0.036 0.38"
        rpy="0.0262 0 0" />
      <geometry>
