  <joint
    name="turret_joint"
    type="continuous">
    <origin
      xyz="0.40 0 0.2575"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="turret_link" />
    <axis
      xyz="0 0 1" />
  </joint>  
  
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
      <parent link="base_footprint"/>
      <child link="base_link"/>
      <origin xyz="-0.167 0.0 0.125" rpy="0 0 0"/>
  </joint>

  <!-- Hidden support casters for Gazebo physics.
       The full turret STL already contains the visible caster geometry, but
       using that detailed mesh as the contact surface makes the turret legs
       take the load before the drive wheels. These simple spheres provide
       stable, low-friction support at the leg contact points. -->
  <link name="turret_caster_fl">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.025"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
    </collision>
  </link>

  <joint name="turret_caster_fl_joint" type="fixed">
    <origin xyz="-0.3848 0.2810 -0.335" rpy="0 0 0"/>
    <parent link="turret_link"/>
    <child link="turret_caster_fl"/>
  </joint>

  <link name="turret_caster_fr">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.025"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
    </collision>
  </link>

  <joint name="turret_caster_fr_joint" type="fixed">
    <origin xyz="-0.3820 -0.2838 -0.335" rpy="0 0 0"/>
    <parent link="turret_link"/>
    <child link="turret_caster_fr"/>
  </joint>

  <link name="turret_caster_bl">
