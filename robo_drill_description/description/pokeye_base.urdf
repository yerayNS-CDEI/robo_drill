<robot
  xmlns:xacro="http://ros.org/wiki/xacro" name="Pokeye">

  <!-- Define robot constants -->
  <xacro:property name="turret_height" value="0.162"/>
  <xacro:property name="bar_thickness" value="0.04"/>
  <xacro:property name="wheel_radius" value="0.125"/>
  <xacro:property name="wheel_zoff" value="0.05"/>
  <xacro:property name="friction_coefficient_1" value="10"/>
  <xacro:property name="friction_coefficient_2" value="10"/>
  <xacro:property name="support_height" value="0.509"/>

  <!-- ===== Drill tool-tip frame =========================================== -->
  <!-- `drill_tip` is a fixed frame at the tip of the drill bit, rigidly        -->
  <!-- attached to the last moving link (stage4_horizontal_link). The drill     -->
  <!-- body extends along -Z of stage4_horizontal_link (see its collision box,  -->
  <!-- which spans z = 0 .. -0.15). These offsets are a PLACEHOLDER: measure    -->
  <!-- the real bit-tip position/orientation on the tool and update them here.  -->
  <xacro:property name="drill_tip_x" value="0.05"/>
  <xacro:property name="drill_tip_y" value="-0.2"/>
  <xacro:property name="drill_tip_z" value="0.0"/>
  <xacro:property name="drill_tip_roll" value="1.5708"/>
  <xacro:property name="drill_tip_pitch" value="0.0"/>
  <xacro:property name="drill_tip_yaw" value="0.0"/>

  <!-- ===== Base-mounted actuator mount points ============================= -->
  <!-- Both sit forward of base_link origin (+x) and above it (+z), below the  -->
  <!-- turret mount (z = 0.2575). The brake motor is the further one in +x.    -->
  <!-- These offsets are a PLACEHOLDER: measure the real mounting positions    -->
  <!-- on the chassis and update them here.                                    -->
  <xacro:property name="hydraulic_valve_x" value="0.71"/>
  <xacro:property name="hydraulic_valve_y" value="0.0"/>
  <xacro:property name="hydraulic_valve_z" value="0.15"/>
  <xacro:property name="caster_brake_x" value="0.79"/>
  <xacro:property name="caster_brake_y" value="0.0"/>
  <xacro:property name="caster_brake_z" value="0.15"/>

  <link
    name="base_link">
    <inertial>
      <!-- CoM biased forward along +x of base_link (toward the turret/front) -->
      <origin
        xyz="0.30 0.0 0.0"
        rpy="0 0 0" />
      <mass value="15.0"/>
      <inertia
        ixx="0.25404237445799095"
        ixy="1.4121324289112278e-14"
        ixz="-0.003497109609384773"
        iyy="0.41070585079970945"
        iyz="-2.0397902292779115e-16"
        izz="0.50178022389242"/>
    </inertial>
    <visual>
      <origin
        xyz="-0.075 0 0.22"
        rpy="1.5708 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_base_v2.stl"  scale="0.001 0.001 0.001"/>
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="-0.075 0 0.22"
        rpy="1.5708 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_base_v2.stl"  scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <link
    name="drivewhl_r_joint_link">
    <inertial>
      <origin
        xyz="-2.77555756156289E-17 1.38777878078145E-17 -0.00433895556276356"
        rpy="0 0 0" />
      <mass
        value="27.24055354973625" />
      <inertia
        ixx="0.135985035679444"
        ixy="19.4114540522268E-18"
        ixz="-49.1257109838198E-19"
        iyy="0.135985035679444"
        iyz="-7.4177739827845E-18"
        izz="0.2031187280856825" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 1.5708 0" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/right_wheel.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.0 0.0 0.0 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 1.5708 0" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/right_wheel.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="drivewhl_r_joint"
    type="continuous">
    <origin
      xyz="0 -0.40275 0"
      rpy="-1.5708 0 0" />
    <parent
      link="base_link" />
    <child
      link="drivewhl_r_joint_link" />
    <axis
      xyz="0 0 1" />
    <limit effort="500.0" velocity="50.0"/>
  </joint>
  <link
    name="drivewhl_l_joint_link">
    <inertial>
      <origin
        xyz="2.77555756156289E-17 0 -0.00433895556276352"
        rpy="0 0 0" />
      <mass
        value="27.24055354973625" />
      <inertia
        ixx="0.135985035679444"
        ixy="-10.52150798691795E-18"
        ixz="11.5717039611713E-19"
        iyy="0.135985035679444"
        iyz="28.7983624641597E-19"
        izz="0.2031187280856825" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 -1.5708 0" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/left_wheel.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.0 0.0 0.0 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 -1.5708 0" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/left_wheel.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="drivewhl_l_joint"
    type="continuous">
    <origin
      xyz="0 0.40275 0"
      rpy="-1.5708 0 0" />
    <parent
      link="base_link" />
    <child
      link="drivewhl_l_joint_link" />
    <axis
      xyz="0 0 1" />
    <limit effort="500.0" velocity="50.0"/>
  </joint>
  <link
    name="turret_link">
    <inertial>
      <origin
        xyz="0.40 0 0.05"
        rpy="0 0 0" />
      <mass value="10.0"/>
      <inertia
        ixx="0.625"
        ixy="0.0"
        ixz="0.0"
        iyy="0.875"
        iyz="0.0"
        izz="0.875"/>
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_p_estructura_redesing.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <!-- Fixed outer sleeve for the vertical (Z) gantry stage.
         The prismatic child link (stage1_lift_link) is the moving inner stage; this
         sleeve keeps the structure visually connected when the stage is extended. -->
    <visual>
      <origin
        xyz="0.28 0.07 -0.047"
        rpy="0 0 3.1416" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_e_stage_1_v3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="1.5708 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_e_stage_1_v3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint
    name="turret_joint"
    type="continuous">
    <origin
      xyz="0.40 0 0.2575"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="turret_link" />
    <axis
      xyz="0 0 1" />
  </joint>  
  
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
      <parent link="base_footprint"/>
      <child link="base_link"/>
      <origin xyz="-0.167 0.0 0.125" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================= -->
  <!-- Base-mounted actuators: hydraulic valve and caster brake.     -->
  <!-- Both are on/off devices, commanded as ros2_control <gpio>     -->
  <!-- components (see robodrill_diffdrive_control.xacro), not as    -->
  <!-- joints - neither has a position, and neither moves anything   -->
  <!-- relative to the chassis.                                      -->
  <!--                                                               -->
  <!-- The links below exist purely to show where the hardware sits: -->
  <!-- robot_state_publisher gives them a static TF and RViz renders -->
  <!-- them, with no controller or joint state involved. The fixed   -->
  <!-- joints are what makes that free - a movable joint would need  -->
  <!-- ros2_control to publish a position that does not exist.       -->
  <!-- Mass and box sizes are PLACEHOLDER: measure the real units.   -->
  <!-- ============================================================= -->

  <!-- Hydraulic valve -->
  <link name="hydraulic_valve_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.00083" ixy="0.0" ixz="0.0"
               iyy="0.00083" iyz="0.0" izz="0.00083" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.08 0.08" />
      </geometry>
      <material name="">
        <color rgba="0.1 0.4 0.8 1" />
      </material>
    </visual>
  </link>
  <joint name="hydraulic_valve_joint" type="fixed">
    <origin
      xyz="${hydraulic_valve_x} ${hydraulic_valve_y} ${hydraulic_valve_z}"
      rpy="0 0 0" />
    <parent link="base_link" />
    <child link="hydraulic_valve_link" />
  </joint>

  <!-- Caster brake motor -->
  <link name="caster_brake_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.00083" ixy="0.0" ixz="0.0"
               iyy="0.00083" iyz="0.0" izz="0.00083" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.10 0.10 0.12" />
      </geometry>
      <material name="">
        <color rgba="0.8 0.3 0.1 1" />
      </material>
    </visual>
  </link>
  <joint name="caster_brake_joint" type="fixed">
    <origin
      xyz="${caster_brake_x} ${caster_brake_y} ${caster_brake_z}"
      rpy="0 0 0" />
    <parent link="base_link" />
    <child link="caster_brake_link" />
  </joint>

  <link
    name="stage1_lift_link">
    <inertial>
      <origin
        xyz="0 0 0.0"
        rpy="0 0 0" />
      <mass value="0.5"/>
      <inertia
        ixx="0.022470833333333335"
        ixy="0.0"
        ixz="0.0"
        iyy="0.022354166666666668"
        iyz="0.0"
        izz="0.0004166666666666667"/>
    </inertial>
    <visual>
      <origin
        xyz="0.12 0.036 0.38"
        rpy="0.0262 0 0" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_e_stage_2_v3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0.12 0.036 0.38"
        rpy="0.0262 0 0" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_e_stage_2_v3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint
    name="stage1_lift_joint"
    type="prismatic">
    <origin
      xyz="0.2905 0 0"
      rpy="0 0 0" />
    <parent
      link="turret_link" />
    <child
      link="stage1_lift_link" />
        <axis
    xyz="0 0 1" />
  <limit
    lower="-0.47"
    upper="0.40"
    effort="1000.0"
    velocity="0.1" />
  </joint>

  <!-- ============================================================= -->
  <!-- Pokeye 3-stage linear-actuator gantry + end rotation.         -->
  <!-- Stage 1 (stage1_lift_joint) vertical lift is the joint above. -->
  <!-- Stage 2 (stage2_lift_joint) second vertical lift.             -->
  <!-- Stage 3 (stage3_rotate_joint) tool rotation about Z.          -->
  <!-- Stage 4 (stage4_horizontal_joint) horizontal lateral motion, the last stage. -->
  <!-- NOTE: stage 3 (rotary) carries stage 4 (horizontal slide), so -->
  <!-- the horizontal travel direction rotates with stage 3.         -->
  <!-- NOTE: the horizontal and rotary stages were previously swapped;-->
  <!-- reality is rotary (3) -> horizontal (4). -->
  <!-- Geometry is placeholder rectangular prisms; refine as needed. -->
  <!-- ============================================================= -->

  <!-- Stage 2 - second vertical lift, mounted on top of stage 1 -->
  <link name="stage2_lift_link">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0" />
      <mass value="1.5" />
      <inertia ixx="0.0325" ixy="0.0" ixz="0.0"
               iyy="0.00305" iyz="0.0" izz="0.03305" />
    </inertial>
    <visual>
      <origin xyz="0.08 0 0" rpy="0 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/rotatory-RL_D_50_102_48_01035.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 -0.265 0.1" rpy="1.5708 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/rotatory-RL_D_50_102_48_01035.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint name="stage2_lift_joint" type="prismatic">
    <origin xyz="0.15 0 0.423" rpy="0 0 0" />
    <parent link="stage1_lift_link" />
    <child link="stage2_lift_link" />
    <axis xyz="0 0 1" />
    <limit lower="0.0" upper="1.0" effort="500.0" velocity="0.2" />
  </joint>

  <!-- Stage 3 - rotary actuator, mounted on the stage 2 carriage. Rotates the -->
  <!-- horizontal reach stage (stage 4) about the vertical Z axis.             -->
  <link name="stage3_rotate_link">
    <inertial>
      <origin xyz="0.15 0 0.05" rpy="0 0 0" />
      <mass value="1.0" />
      <inertia ixx="0.00165" ixy="0.0" ixz="0.0"
               iyy="0.02165" iyz="0.0" izz="0.02165" />
    </inertial>
    <visual>
      <origin xyz="-0.33 0.0 0.05" rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_e_stage_3_v3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.059 0.065 -0.09" rpy="0 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_e_stage_3_v3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint name="stage3_rotate_joint" type="revolute">
    <origin xyz="0.08 0 0.10" rpy="1.5708 0 1.5708" />
    <parent link="stage2_lift_link" />
    <child link="stage3_rotate_link" />
    <axis xyz="0 0 1" />
    <limit lower="-3.1416" upper="3.1416" effort="100.0" velocity="1.0" />
  </joint>

  <!-- Stage 4 - horizontal reach stage (the last stage), mounted on the rotary  -->
  <!-- stage 3. Slides laterally; its travel direction rotates with stage 3.     -->
  <!-- Carries the drill tool (collision box below; drill_tip frame at its end). -->
  <link name="stage4_horizontal_link">
    <inertial>
      <origin xyz="0 0 -0.075" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.0012" ixy="0.0" ixz="0.0"
               iyy="0.0012" iyz="0.0" izz="0.00055" />
    </inertial>
    <collision>
      <origin xyz="0 0 -0.075" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.08 0.15" />
      </geometry>
    </collision>
  </link>
  <joint name="stage4_horizontal_joint" type="prismatic">
    <origin xyz="0.0 0.0 0.08" rpy="-1.5708 -1.5708 0" />
    <parent link="stage3_rotate_link" />
    <child link="stage4_horizontal_link" />
    <!-- local X of this (rotated) frame points along world Y at zero rotation, -->
    <!-- giving lateral horizontal travel that follows stage 3's rotation.      -->
    <axis xyz="0 1 0" />
    <limit lower="-0.196" upper="0.196" effort="500.0" velocity="0.2" />
  </joint>

  <!-- Drill tool-tip frame: fixed to the end-rotation link. robot_state_publisher -->
  <!-- emits its TF automatically (no controller/ros2_control entry needed). -->
  <link name="drill_tip"/>
  <joint name="drill_tip_joint" type="fixed">
    <origin
      xyz="${drill_tip_x} ${drill_tip_y} ${drill_tip_z}"
      rpy="${drill_tip_roll} ${drill_tip_pitch} ${drill_tip_yaw}" />
    <parent link="stage4_horizontal_link" />
    <child link="drill_tip" />
  </joint>

  <!-- Add Gazebo materials for the pokeye links -->
  <gazebo reference="base_link">
      <collide_bitmask>0</collide_bitmask>
  </gazebo>

  <gazebo reference="turret_link">
      <collide_bitmask>0</collide_bitmask>
      <gravity>false</gravity>
  </gazebo>

  <gazebo reference="stage1_lift_link">
    <collide_bitmask>0</collide_bitmask>
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="stage2_lift_link">
    <collide_bitmask>0</collide_bitmask>
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="stage3_rotate_link">
    <collide_bitmask>0</collide_bitmask>
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="stage4_horizontal_link">
    <collide_bitmask>0</collide_bitmask>
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="drivewhl_l_joint_link">
      <mu1>2.0</mu1>
      <mu2>2.0</mu2>
      <kp>5000000.0</kp>
      <kd>10.0</kd>
      <minDepth>0.002</minDepth>
      <maxVel>50.0</maxVel>
      <!-- <fdir1>1 0 0</fdir1> -->
  </gazebo>

  <gazebo reference="drivewhl_r_joint_link">
      <mu1>2.0</mu1>
      <mu2>2.0</mu2>
      <kp>5000000.0</kp>
      <kd>10.0</kd>
      <minDepth>0.002</minDepth>
      <maxVel>50.0</maxVel>
      <!-- <fdir1>1 0 0</fdir1> -->
  </gazebo>

  <!-- Add damping to wheel joints -->
  <gazebo reference="drivewhl_l_joint">
      <provideFeedback>true</provideFeedback>
  </gazebo>

  <gazebo reference="drivewhl_r_joint">
      <provideFeedback>true</provideFeedback>
  </gazebo>

</robot>
