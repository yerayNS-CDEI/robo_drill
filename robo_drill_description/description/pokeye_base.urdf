  <joint
    name="gantry_lift1_joint"
    type="prismatic">
    <origin
      xyz="0.2905 0 0"
      rpy="0 0 0" />
    <parent
      link="turret_link" />
    <child
      link="gantry_lift1_link" />
        <axis
    xyz="0 0 1" />
  <limit
    lower="-0.47"
    upper="0.40"
    effort="1000.0"
    velocity="0.1" />
  </joint>

  <!-- ============================================================= -->
  <!-- Pokeye 3-stage linear-actuator gantry + end rotation.         -->
  <!-- Stage 1 (gantry_lift1_joint) vertical lift is the joint above. -->
  <!-- Stage 2 (gantry_lift2_joint) second vertical lift.             -->
  <!-- Stage 3 (gantry_lateral_joint) horizontal lateral motion (Y). -->
  <!-- Stage 4 (gantry_rotate_joint) tool rotation about Z.           -->
  <!-- Geometry is placeholder rectangular prisms; refine as needed. -->
  <!-- ============================================================= -->

  <!-- Stage 2 - second vertical lift, mounted on top of stage 1 -->
  <link name="gantry_lift2_link">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0" />
      <mass value="1.5" />
      <inertia ixx="0.0325" ixy="0.0" ixz="0.0"
               iyy="0.00305" iyz="0.0" izz="0.03305" />
    </inertial>
    <visual>
      <origin xyz="0 -0.265 0.1" rpy="1.5708 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_e_stage_3_v3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 -0.265 0.1" rpy="1.5708 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/d_e_stage_3_v3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint name="gantry_lift2_joint" type="prismatic">
    <origin xyz="0.19 0 0.423" rpy="0 0 0" />
    <parent link="gantry_lift1_link" />
    <child link="gantry_lift2_link" />
    <axis xyz="0 0 1" />
    <limit lower="0.0" upper="1.0" effort="500.0" velocity="0.2" />
  </joint>

  <!-- Stage 3 - lateral (horizontal Y) beam, mounted on the stage 2 carriage -->
  <link name="gantry_lateral_link">
    <inertial>
      <origin xyz="0.15 0 0.05" rpy="0 0 0" />
      <mass value="1.0" />
      <inertia ixx="0.00165" ixy="0.0" ixz="0.0"
               iyy="0.02165" iyz="0.0" izz="0.02165" />
    </inertial>
    <visual>
      <origin xyz="0.059 0.065 -0.09" rpy="0 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/rotatory-RL_D_50_102_48_01035.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.059 0.065 -0.09" rpy="0 0 1.5708" />
      <geometry>
        <mesh
          filename="package://robo_drill/robo_drill_description/meshes/rotatory-RL_D_50_102_48_01035.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <joint name="gantry_lateral_joint" type="prismatic">
    <origin xyz="0 0 0.10" rpy="0 0 0" />
    <parent link="gantry_lift2_link" />
    <child link="gantry_lateral_link" />
    <axis xyz="0 1 0" />
    <limit lower="-0.196" upper="0.196" effort="500.0" velocity="0.2" />
  </joint>

  <!-- End rotation - tool that rotates about Z, at the front of the reach beam -->
  <link name="gantry_rotate_link">
    <inertial>
      <origin xyz="0 0 -0.075" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.0012" ixy="0.0" ixz="0.0"
               iyy="0.0012" iyz="0.0" izz="0.00055" />
    </inertial>
    <collision>
      <origin xyz="0 0 -0.075" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.08 0.15" />
      </geometry>
    </collision>
  </link>
  <joint name="gantry_rotate_joint" type="revolute">
    <origin xyz="0.06 0.06 0.0" rpy="1.5708 0 1.5708" />
    <parent link="gantry_lateral_link" />
    <child link="gantry_rotate_link" />
    <axis xyz="0 0 1" />
    <limit lower="-3.1416" upper="3.1416" effort="100.0" velocity="1.0" />
  </joint>

  <!-- Drill tool-tip frame: fixed to the end-rotation link. robot_state_publisher -->
  <!-- emits its TF automatically (no controller/ros2_control entry needed). -->
  <link name="drill_tip"/>
  <joint name="drill_tip_joint" type="fixed">
    <origin
      xyz="${drill_tip_x} ${drill_tip_y} ${drill_tip_z}"
      rpy="${drill_tip_roll} ${drill_tip_pitch} ${drill_tip_yaw}" />
    <parent link="gantry_rotate_link" />
    <child link="drill_tip" />
  </joint>

  <!-- Add Gazebo materials for the pokeye links -->
  <gazebo reference="base_link">
      <collide_bitmask>0</collide_bitmask>
  </gazebo>

  <gazebo reference="turret_link">
      <collide_bitmask>0</collide_bitmask>
      <gravity>false</gravity>
  </gazebo>

  <gazebo reference="gantry_lift1_link">
    <collide_bitmask>0</collide_bitmask>
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="gantry_lift2_link">
    <collide_bitmask>0</collide_bitmask>
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="gantry_lateral_link">
    <collide_bitmask>0</collide_bitmask>
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="gantry_rotate_link">
    <collide_bitmask>0</collide_bitmask>
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="drivewhl_l_joint_link">
      <mu1>2.0</mu1>
      <mu2>2.0</mu2>
      <kp>5000000.0</kp>
      <kd>10.0</kd>
      <minDepth>0.002</minDepth>
      <maxVel>50.0</maxVel>
      <!-- <fdir1>1 0 0</fdir1> -->
  </gazebo>

  <gazebo reference="drivewhl_r_joint_link">
      <mu1>2.0</mu1>
      <mu2>2.0</mu2>
      <kp>5000000.0</kp>
      <kd>10.0</kd>
      <minDepth>0.002</minDepth>
      <maxVel>50.0</maxVel>
      <!-- <fdir1>1 0 0</fdir1> -->
  </gazebo>

  <!-- Add damping to wheel joints -->
  <gazebo reference="drivewhl_l_joint">
      <provideFeedback>true</provideFeedback>
  </gazebo>

  <gazebo reference="drivewhl_r_joint">
      <provideFeedback>true</provideFeedback>
  </gazebo>

  <gazebo reference="turret_caster_fl">
      <mu1>0.001</mu1>
      <mu2>0.001</mu2>
      <kp>1000000.0</kp>
      <kd>50.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.1</maxVel>
  </gazebo>

  <gazebo reference="turret_caster_fr">
      <mu1>0.001</mu1>
      <mu2>0.001</mu2>
      <kp>1000000.0</kp>
      <kd>50.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.1</maxVel>
  </gazebo>

  <gazebo reference="turret_caster_bl">
      <mu1>0.001</mu1>
      <mu2>0.001</mu2>
      <kp>1000000.0</kp>
      <kd>50.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.1</maxVel>
  </gazebo>

  <gazebo reference="turret_caster_br">
      <mu1>0.001</mu1>
      <mu2>0.001</mu2>
      <kp>1000000.0</kp>
      <kd>50.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.1</maxVel>
  </gazebo>
  
</robot>
